# ─────────────────────────────────────────────────────────────────
# ARD City Sales Intelligence — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────

# Next.js runtime
NODE_ENV=development

# Postgres connection string (Neon)
DATABASE_URL=postgresql://username:password@ep-example-region.aws.neon.tech/neondb?sslmode=require

# Anthropic API Key — required for AI Review and AI Summary features
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# All current application routes are native in Next.js.
